# ----- Shared -----
NODE_ENV=development

# ----- API (packages/api) -----
# Postgres connection string used by Prisma. Must match docker-compose.yml.
DATABASE_URL=postgresql://breaklog:breaklog@localhost:5433/breaklog?schema=public

# Port the Fastify API listens on.
API_PORT=4000
API_ORIGIN=http://localhost:4000

# Allowed CORS origin for the web app.
WEB_ORIGIN=http://localhost:5173

# Secret used to sign session JWTs. Generate with: `openssl rand -base64 48`.
JWT_SECRET=replace-me-with-a-long-random-string

# Google OAuth 2.0 (Web client in Google Cloud Console).
# Authorized redirect URI must be: ${API_ORIGIN}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- Seed data (packages/api, dev only) -----
# Real Google emails so these users can sign in via Google immediately.
SEED_ADMIN_EMAIL=vik@example.com
SEED_INSTRUCTOR_EMAILS=alice@example.com,bob@example.com

# ----- Observability (optional) -----
# If set, Sentry is initialized and unhandled errors are reported. Leave empty to disable.
SENTRY_DSN=
# Reserved for a future pino transport that ships to Axiom/Logtail/etc.
LOG_SHIPPER_URL=

# ----- Web (packages/web) -----
VITE_API_ORIGIN=http://localhost:4000
VITE_SENTRY_DSN=
